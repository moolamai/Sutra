{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moolam.ai/schemas/bindings-vision.textbook-page.v1.json",
  "title": "Generic textbook page extraction",
  "description": "VisionInterface responseSchema for a single photographed textbook / workbook page. Nullable fields mean illegible/unknown. Single page only (pageIndex must be 0).",
  "schemaVersion": "bindings-vision.textbook-page.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "documentKind",
    "pageIndex",
    "confidence",
    "blocks",
    "partial"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "bindings-vision.textbook-page.v1"
    },
    "documentKind": {
      "type": "string",
      "const": "textbook-page"
    },
    "title": {
      "type": ["string", "null"],
      "description": "Page or section title when readable; null when unknown."
    },
    "chapter": {
      "type": ["string", "null"],
      "description": "Chapter label when readable; null when unknown."
    },
    "pageNumber": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Printed page number when readable; null when unknown — never invent."
    },
    "pageIndex": {
      "type": "integer",
      "const": 0,
      "description": "Caller passes one page image; multi-image batches are rejected by the document path."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "blocks": {
      "type": "array",
      "maxItems": 64,
      "description": "Bounded reading-order blocks on the page.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "confidence"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["heading", "paragraph", "figure", "equation", "table", "other"]
          },
          "text": {
            "type": ["string", "null"],
            "description": "Extracted text; null for non-text or illegible blocks."
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "partial": {
      "type": "boolean",
      "description": "true when extraction is incomplete."
    },
    "unresolvedFields": {
      "type": "array",
      "maxItems": 64,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    }
  }
}


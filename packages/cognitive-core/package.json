{
  "name": "@moolam/cognitive-core",
  "version": "0.1.0",
  "description": "The cognitive core. Domain-agnostic composition of the cognitive primitives (memory, model, reasoning, speech, vision, tools, planning, knowledge) into one perceive-recall-reason-act-reflect loop.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/core_loop.test.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@moolam/contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}

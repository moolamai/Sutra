{
  "schemaVersion": "bindings-slm.cert-profile.v1",
  "profileId": "desktop",
  "adapter": "llamacpp",
  "description": "CPU desktop certification for LlamaCppSlmRuntime: B0 model suite, B1 zero-egress, P4 core_loop + first_token budgets (relative regression on CPU quant).",
  "hardware": {
    "class": "cpu",
    "gpuRequired": false,
    "quantPolicy": "CPU quant with documented expected latency; CI gates use relative regression vs recorded baseline, not absolute mobile SLA"
  },
  "modelArtifact": {
    "name": "phi-ck03-llama",
    "format": "gguf",
    "quantization": "Q4_K_M",
    "fixtureRelpath": "certification/fixtures/desktop-minimal.gguf",
    "artifactSha256": "f1ae43bcd01bb341ebe4159b0dd0f5ca6742d7a3680b65d3469a5b9af04d02b9",
    "llamaCppPinnedRevision": "b5750"
  },
  "obligations": {
    "b0Model": ["CK-03.1", "CK-03.2", "CK-03.3"],
    "b1Locality": {
      "harness": "egress-recorder",
      "zeroEgressOps": ["generate", "embed"],
      "obligationId": "CK-03.3",
      "policyId": "sovereign-default"
    }
  },
  "benches": {
    "subset": ["core_loop", "first_token"],
    "gates": {
      "core_loop": {
        "benchId": "core_loop",
        "nfrId": "NFR-06",
        "thresholdsRelpath": "benchmarks/gates/thresholds.json",
        "baselineRelpath": "benchmarks/gates/baseline.json",
        "policy": "absolute-ceiling-plus-relative-baseline"
      },
      "first_token": {
        "metricId": "first_token",
        "nfrId": "NFR-01",
        "budgetP95Ms": 1500,
        "policy": "relative-vs-profile-floor",
        "floorP95Ms": 50,
        "notes": "Mid-range Android NFR-01 is ≤1.5s p95; desktop CPU CI asserts first stream delta under floorP95Ms when using the in-process FFI stand-in (native addon may raise floor in recorded baseline)."
      }
    }
  },
  "subjectId": "cert.desktop.llamacpp",
  "deviceId": "ci-desktop-cpu",
  "segfaultRetry": {
    "maxAttempts": 2,
    "matchClasses": ["segfault", "SIGSEGV", "native crash"]
  },
  "observability": {
    "event": "bindings_slm.certify",
    "emitContentBodies": false
  },
  "reportArtifact": {
    "schemaVersion": "bindings-slm.cert-report.v1",
    "ciRelpath": "artifacts/llama-cpp-desktop-cert/desktop.cert.json",
    "contains": [
      "obligationVerdicts",
      "egressRecord",
      "p95Benches",
      "offlineTurn",
      "modelArtifactSha256",
      "llamaCppPinnedRevision"
    ]
  },
  "offlineTurn": {
    "exampleRelpath": "examples/offline-edge/main-llamacpp.mjs",
    "goldenRelpath": "examples/offline-edge/golden-turn.json",
    "network": "denied",
    "requires": ["CognitiveCore.turn", "LlamaCppSlmRuntime", "servedLocally", "frictionFold", "turn.completed"]
  }
}

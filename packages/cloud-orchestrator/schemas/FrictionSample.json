{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "assistanceRequested": {
      "type": "boolean"
    },
    "capturedAt": {
      "pattern": "^\\d{15}:\\d{6}:[A-Za-z0-9_-]{4,64}$",
      "type": "string"
    },
    "conceptId": {
      "minLength": 1,
      "type": "string"
    },
    "hesitationMs": {
      "minimum": 0,
      "type": "integer"
    },
    "inputVelocity": {
      "minimum": 0,
      "type": "number"
    },
    "outcome": {
      "enum": [
        "correct",
        "incorrect",
        "partial",
        "ungraded"
      ],
      "type": "string"
    },
    "revisionCount": {
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "assistanceRequested",
    "capturedAt",
    "conceptId",
    "hesitationMs",
    "inputVelocity",
    "outcome",
    "revisionCount"
  ],
  "title": "FrictionSample",
  "type": "object",
  "x-protocol-version": "1.0.0"
}

{
  "name": "@moolam/runtime",
  "version": "1.1.0",
  "description": "Internal component of Sutra SDK — applications should install sutra-sdk. Reference runtime: agent lifecycle host, in-process task scheduler, and event bus. Edge and cloud share the runtime contracts from @moolam/contracts; this package provides the portable implementations.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/moolamai/sutra/tree/main/packages/runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moolamai/sutra.git",
    "directory": "packages/runtime"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/runtime.test.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@moolam/contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}

{
  "name": "@moolam/contracts",
  "version": "0.1.0",
  "description": "Pure cognitive contracts: memory, model, reasoning, planning, knowledge, tool, vision, speech, and runtime interfaces. Zero dependencies, zero implementations.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/contract_shapes.test.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}

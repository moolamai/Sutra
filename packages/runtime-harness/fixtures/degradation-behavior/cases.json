{
  "description": "Per-behavior regression cases for the host degradation registry — stub failure, assert Behavior + signal; metadata only.",
  "cases": [
    {
      "id": "behavior-stale-sync-read",
      "specId": "degradation-contract",
      "protects": "Sync read failure serves last-known-good with freshness marker and DEGRADE_STALE_READ; never fabricates.",
      "subjectId": "anika-k",
      "deviceId": "edge-aaaa",
      "dependency": "sync",
      "operation": "read",
      "forcedFailure": {
        "kind": "timeout",
        "dependency": "cloud-sync"
      },
      "expectedBehavior": "stale_with_marker",
      "expectedSignalCode": "DEGRADE_STALE_READ",
      "expectedOk": true,
      "expectedDegraded": true,
      "requiresLastKnownGood": true,
      "allowsFabrication": false,
      "allowsSilentWriteRetry": false,
      "idempotencyKey": "anika-k:sync:read:stale-1"
    },
    {
      "id": "behavior-queue-model-read",
      "specId": "degradation-contract",
      "protects": "Model read failure queues with DEGRADE_QUEUE_AND_WARN — blocked with advisory, never silent continue.",
      "subjectId": "anika-k",
      "deviceId": "edge-aaaa",
      "dependency": "model",
      "operation": "read",
      "forcedFailure": {
        "kind": "dependency_unavailable",
        "dependency": "slm-runtime"
      },
      "expectedBehavior": "queue",
      "expectedSignalCode": "DEGRADE_QUEUE_AND_WARN",
      "expectedOk": false,
      "expectedDegraded": true,
      "requiresEnqueue": true,
      "allowsFabrication": false,
      "allowsSilentWriteRetry": false,
      "idempotencyKey": "anika-k:model:read:queue-1"
    },
    {
      "id": "behavior-hard-stop-sync-write",

{
  "name": "sutra",
  "version": "0.1.0",
  "private": true,
  "description": "Sutra — Moolam open cognitive infrastructure. Reusable, domain-agnostic foundation for autonomous cognitive companions: contracts, cognitive core, runtime, sync protocol, edge and cloud hosts.",
  "license": "Apache-2.0",
  "author": "Moolam AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/moolamai/sutra"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint && pnpm deps:lint",
    "test": "turbo run test",
    "schemas:drift": "node scripts/check-schema-drift.mjs",
    "schemas:drift:prove": "node scripts/prove-schema-drift-gate.mjs",
    "protocol:version-bump": "node scripts/check-protocol-version-bump.mjs",
    "protocol:version-bump:record": "node scripts/check-protocol-version-bump.mjs --record",
    "protocol:version-bump:prove": "node scripts/prove-protocol-version-bump-gate.mjs",
    "golden:joins": "pnpm exec turbo run build --filter=@moolam/sync-protocol && node --test packages/sync-protocol/tests/golden_joins.test.mjs",
    "golden:joins:prove": "node scripts/prove-golden-joins-gate.mjs",
    "guidance:eval": "pnpm --filter @moolam/guidance-evals gate",
    "guidance:eval:prove": "node scripts/prove-guidance-eval-gate.mjs",
    "golden:turns": "pnpm exec turbo run build --filter=@moolam/sync-protocol && node --test packages/sync-protocol/tests/golden_turns.test.mjs",
    "golden:turns:prove": "node scripts/prove-golden-turns-gate.mjs",
    "golden:fuzz": "pnpm --filter @moolam/runtime-harness run golden:fuzz",
    "golden:fuzz:prove": "node scripts/prove-parser-chunk-fuzz-gate.mjs",
    "conformance": "node scripts/check-conformance.mjs",
    "conformance:prove": "node scripts/prove-conformance-gate.mjs",
    "independence-kit:prove": "node scripts/prove-independence-kit.mjs",
    "certification:run": "node artifacts/independent-certification/scripts/run-certification.mjs",
    "certification:run:prove": "node scripts/prove-independent-certification.mjs",
    "certification:run:test": "node --test artifacts/independent-certification/tests/certification_run.test.mjs",
    "certification:freeze:prove": "node scripts/prove-certification-freeze-publish.mjs",
    "protocol:bump:1.0.0": "node scripts/bump-protocol-1-0-0.mjs",
    "conformance:coverage": "node scripts/generate-conformance-coverage.mjs",
    "conformance:coverage:check": "node scripts/check-conformance-coverage.mjs",
    "mocks:conformance": "node scripts/check-mock-conformance.mjs",
    "mocks:conformance:prove": "node scripts/prove-mock-conformance-gate.mjs",
    "deps:lint": "node scripts/check-dependency-direction.mjs",
    "deps:lint:prove": "node scripts/prove-dependency-direction-gate.mjs",
    "publish:readiness": "node scripts/check-package-publish-readiness.mjs",
    "publish:readiness:prove": "node scripts/prove-package-publish-readiness-gate.mjs",
    "publish:pack": "node scripts/check-package-publish-readiness.mjs --pack-only",
    "publish:pack:prove": "node scripts/prove-package-publish-pack-gate.mjs",
    "publish:check": "pnpm build && node scripts/check-package-publish-readiness.mjs --pack",
    "changeset": "changeset",
    "changeset:config": "node scripts/check-changeset-config.mjs",
    "changeset:version": "node scripts/run-changeset-version.mjs",
    "changeset:publish": "node scripts/run-changeset-publish.mjs",
    "publish:provenance": "node scripts/check-release-provenance.mjs",
    "publish:integrity:record": "node scripts/check-pack-integrity.mjs --record",
    "publish:integrity:verify": "node scripts/check-pack-integrity.mjs --verify",
    "publish:integrity:prove": "node scripts/prove-pack-integrity-gate.mjs",
    "publish:rehearsal:verify": "node scripts/verify-rehearsal-install.mjs --from-local-packs",
    "publish:rehearsal:prove": "node scripts/prove-rehearsal-install-gate.mjs",
    "release:tag-rehearsal": "node scripts/release-tag-rehearsal.mjs --write",
    "release:tag-rehearsal:prove": "node scripts/release-tag-rehearsal.mjs --prove --write",
    "pypi:wheel": "node scripts/check-pypi-wheel-pipeline.mjs",
    "pypi:wheel:metadata": "node scripts/check-pypi-wheel-pipeline.mjs --metadata-only",
    "pypi:wheel:prove": "node scripts/prove-pypi-wheel-pipeline-gate.mjs",
    "pypi:publish": "node scripts/run-pypi-publish.mjs",
    "pypi:publish:dry-run": "node scripts/run-pypi-publish.mjs --dry-run",
    "pypi:publish:prove": "node scripts/prove-pypi-publish-gate.mjs",
    "pypi:rehearsal:verify": "node scripts/verify-pypi-rehearsal-install.mjs --from-local-dist",
    "version:lockstep:doc": "node scripts/check-version-lockstep-doc.mjs",
    "version:lockstep": "node scripts/check-version-lockstep.mjs",
    "version:lockstep:prove": "node scripts/prove-version-lockstep-gate.mjs",
    "create-sutra": "node tools/create-sutra/bin/create-sutra.mjs",
    "create-sutra:prove": "node scripts/prove-create-sutra-gate.mjs",
    "create-sutra:verify": "node scripts/verify-create-sutra-scaffold.mjs",
    "create-sutra:verify:matrix": "node scripts/verify-create-sutra-scaffold.mjs --matrix",
    "create-sutra:verify:prove": "node scripts/prove-create-sutra-verify-gate.mjs",
    "integration:edge-app:verify": "node scripts/verify-edge-app-template.mjs",
    "integration:edge-app:prove": "node scripts/prove-edge-app-template-gate.mjs",
    "integration:node-service:verify": "node scripts/verify-node-service-template.mjs",
    "integration:fastapi-adapter:verify": "node scripts/verify-fastapi-adapter-template.mjs",
    "integration:templates-002:prove": "node scripts/prove-integration-templates-002-gate.mjs",
    "integration:templates:verify:matrix": "node scripts/verify-integration-templates-matrix.mjs --matrix",
    "integration:templates:verify:prove": "node scripts/prove-integration-templates-matrix-gate.mjs",
    "docs-site:sync": "pnpm --filter @moolam/docs-site docs:sync",
    "docs-site:api": "pnpm --filter @moolam/docs-site docs:api",
    "docs-site:build": "pnpm --filter @moolam/docs-site docs:build",
    "docs-site:check": "node scripts/check-docs-site.mjs",
    "docs-site:prove": "node scripts/prove-docs-site-gate.mjs",
    "implementor-quickstart:check": "node scripts/check-implementor-quickstart.mjs",
    "field-pilot-kit:check": "node scripts/check-field-pilot-kit.mjs",
    "field-pilot:execute": "node scripts/run-field-pilot-execution.mjs",
    "field-pilot:findings:check": "node scripts/check-field-pilot-findings.mjs",
    "field-pilot:exit-review": "node scripts/check-field-pilot-exit-review.mjs",
    "implementor-quickstart:prove": "node scripts/prove-implementor-quickstart-gate.mjs",
    "quic-guides:check": "node scripts/check-quic-conformance-binding-guides.mjs",
    "quic-guides:prove": "node scripts/prove-quic-conformance-binding-guides-gate.mjs",
    "stranger-test:check": "node scripts/check-stranger-test-protocol.mjs",
    "stranger-test:prove": "node scripts/prove-stranger-test-protocol-gate.mjs",
    "stranger-test:triage:check": "node scripts/check-stranger-test-triage.mjs",
    "stranger-test:triage:prove": "node scripts/prove-stranger-test-triage-gate.mjs",
    "threat-model:inventory:check": "node scripts/check-threat-model-inventory.mjs",
    "threat-model:stride:check": "node scripts/check-threat-model-stride.mjs",
    "external-review:check": "node scripts/check-external-review.mjs",
    "security-summary:check": "node scripts/check-security-review-summary.mjs",
    "audit:gate": "node scripts/run-audit-gate.mjs",
    "audit:gate:prove": "node scripts/prove-audit-gate.mjs",
    "audit:policy:check": "node scripts/check-audit-triage-policy.mjs",
    "sbom:generate": "node scripts/generate-release-sbom.mjs",
    "sbom:check": "node scripts/check-release-sbom.mjs",
    "signing:verify": "node scripts/verify-artifact-signing.mjs",
    "freeze-rfc:check": "node scripts/check-freeze-rfc.mjs",
    "production-publish:gate": "node scripts/check-production-publish-gate.mjs",
    "clean": "turbo run clean",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "dependency-cruiser": "^18.1.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "pnpm": {
    "overrides": {
      "@opentelemetry/api": "1.9.0",
      "@opentelemetry/core": "2.0.1",
      "@opentelemetry/sdk-trace-base": "2.0.1",
      "@opentelemetry/sdk-trace-node": "2.0.1",
      "@opentelemetry/sdk-metrics": "2.0.1",
      "@opentelemetry/resources": "2.0.1",
      "@opentelemetry/exporter-trace-otlp-http": "0.203.0",
      "@opentelemetry/exporter-metrics-otlp-http": "0.203.0",
      "@opentelemetry/semantic-conventions": "1.36.0"
    }
  }
}

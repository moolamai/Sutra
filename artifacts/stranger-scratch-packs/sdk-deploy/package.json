{
  "name": "sutra-sdk",
  "version": "0.1.0",
  "description": "The public entry point of the Moolam open cognitive infrastructure. Re-exports the stable APIs of contracts, cognitive-core, runtime, telemetry, sync-protocol, and edge-agent so applications import one package.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/moolamai/sutra/tree/main/packages/sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moolamai/sutra.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@moolam/cognitive-core": "workspace:*",
    "@moolam/contracts": "workspace:*",
    "@moolam/edge-agent": "workspace:*",
    "@moolam/runtime": "workspace:*",
    "@moolam/sync-protocol": "workspace:*",
    "@moolam/telemetry": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
